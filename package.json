{
  "name": "exempel-micro-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/exampleComponent.js",
      "style": "./dist/assets/exampleComponent.css"
    }
  },
  "scripts": {
    "dev": "vite --port 3038 --strictPort",
    "build": "vue-tsc -b && vite build",
    "preview": "vue-tsc -b && vite build && vite preview --port 3039 --strictPort",
    "serve": "vite preview --port 3039 --strictPort",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fkui/date": "^6.26.0",
    "@fkui/design": "^6.26.0",
    "@fkui/logic": "^6.26.0",
    "@fkui/theme-default": "^6.26.0",
    "@fkui/user-lib-design": "^1.2.0",
    "@fkui/vue": "^6.26.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.15.2",
    "@types/node": "^24.10.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.8.1",
    "happy-dom": "^20.9.0",
    "sass-embedded": "^1.93.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.1.3"
  }
}
